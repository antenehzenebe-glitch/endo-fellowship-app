# Supabase configuration — Howard Endo Fellowship App
#
# 1. Copy this file to .env.local
# 2. Fill in real values from Supabase dashboard -> Project Settings -> API
# 3. NEVER commit .env.local or real keys to git
#
# Only the anon key is used in app code; RLS does the enforcing.
# The service-role key must never appear in this repo.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
